# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
POSTGRES_USER=fintech
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=fintech_movements

# Connection string consumed by Prisma / backend.
# For docker-compose the host is the service name "db"; for local dev use localhost.
DATABASE_URL=postgresql://fintech:change_me_in_prod@localhost:5432/fintech_movements?schema=public

# ----------------------------------------------------------------------------
# Backend
# ----------------------------------------------------------------------------
NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:3000

# JWT (RS256). Generate with:
#   openssl genpkey -algorithm RSA -out keys/private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in keys/private.pem -out keys/public.pem
# Then paste PEM contents here (escaped newlines as \n) OR mount via files.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
# Secure flag on auth cookies: 'true' behind HTTPS (production), 'false' for local http.
COOKIE_SECURE=false

# Seed user created on first boot (documented in README)
SEED_USER_EMAIL=demo@fintech.co
SEED_USER_PASSWORD=Demo1234!

# ----------------------------------------------------------------------------
# Frontend
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
